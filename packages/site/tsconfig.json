{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"baseUrl": ".",
		"paths": {
			"@components*": ["components/*"],
			"@i18n*": ["i18n/*"],
			"@data*": ["data/*"],
			"@features*": ["features/*"],
			"@pages*": ["pages/*"],
			"@layouts*": ["layouts/*"],
			"@utils*": ["utils/*"],
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
	],
	"exclude": ["node_modules"]
}
